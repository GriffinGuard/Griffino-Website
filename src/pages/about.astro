---
import BaseLayout from '../layouts/BaseLayout.astro';
import GitHubIcon from '../components/GitHubIcon.astro';
import { ui, defaultLocale } from '../i18n';
const en = ui[defaultLocale];
---
<BaseLayout title="About the Organization · Griffino" description="About the development organization behind Griffino." path="/about.html">
  <main class="content-page">
    <p class="eyebrow" data-i18n="page.about.eyebrow">{en['page.about.eyebrow']}</p>
    <h1 data-i18n="page.about.title">{en['page.about.title']}</h1>
    <p class="hero-copy" data-i18n="page.about.copy">{en['page.about.copy']}</p>

    <section class="content-section">
      <h2>GriffinGuard</h2>
      <p data-i18n="page.about.nameMeaningCopy">{en['page.about.nameMeaningCopy']}</p>
    </section>

    <section class="content-section">
      <h2 data-i18n="page.about.mainContributor">{en['page.about.mainContributor']}</h2>
      <div class="pill-links">
        <a class="social-pill active" href="https://github.com/MorCherlf" target="_blank" rel="noopener noreferrer">
          <GitHubIcon />
          <span>MorCherlf</span>
        </a>
        <a class="social-pill" href="https://github.com/GriffinoBot" target="_blank" rel="noopener noreferrer">
          <GitHubIcon />
          <span data-i18n="page.about.helperBot">{en['page.about.helperBot']}</span>
          <span>GriffinoBot</span>
        </a>
      </div>
    </section>

    <section class="content-section">
